@page "/calculator"

<style>
    .calculator {
        width: 320px;
        margin: auto;
    }

    .display {
        background-color: black;
        color: white;
        font-size: 2rem;
        text-align: right;
        padding: 20px;
        margin-bottom: 10px;
        border-radius: 5px;
        overflow: hidden;
    }

    .buttons {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 5px;
    }

    .lg-buttons {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 5px;
        margin-bottom: 5px;
    }

    /* button .lg-button {
        height: 70px;
        width: 140px;
        font-size: 1.5rem;
        border: none;
        border-radius: 5px;
        cursor: pointer;
    } */

    button {
        height: 70px;
        font-size: 1.5rem;
        border: none;
        border-radius: 5px;
        cursor: pointer;
    }


        button:hover {
            opacity: 0.8;
        }
</style>

<h1>Calculator</h1>

<div class="calculator">

    <div class="display">
        <h3><strong>@Display</strong></h3>
    </div>
    <div class="lg-buttons">
        <button class="lg-button" @onclick="Clear">C</button>
        <button class="" @onclick="BackSpace">BS</button>
    </div>
    <div class="buttons">
        <button @onclick='() => AddDigit("7")'>7</button>
        <button @onclick='() => AddDigit("8")'>8</button>
        <button @onclick='() => AddDigit("9")'>9</button>
        <button @onclick='() => AddOperator("+")'>+</button>

        <button @onclick='() => AddDigit("4")'>4</button>
        <button @onclick='() => AddDigit("5")'>5</button>
        <button @onclick='() => AddDigit("6")'>6</button>
        <button @onclick='() => AddOperator("-")'>-</button>
        
        <button @onclick='() => AddDigit("1")'>1</button>
        <button @onclick='() => AddDigit("2")'>2</button>
        <button @onclick='() => AddDigit("3")'>3</button>
        <button @onclick='() => AddOperator("×")'>×</button>

        <button @onclick='() => AddDigit("0")'>0</button>
        <button @onclick='() => AddDigit(".")'>.</button>
        <button @onclick="Result">=</button>
        <button @onclick='() => AddOperator("÷")'>÷</button>
    </div>
</div>

@code {
    private string Display = "0";

    public void RemoveZeroFromStart()
    {
        if (Display != "0" && Display[0] == '0' && Display[1] != '.')
        {
            Display = Display.Substring(1);
        }
    }

    public void Result()
    {
        try
        {
            double result = 0;
            var expression = new NCalc.Expression(Display.Replace("×", "*").Replace("÷", "/"));
            result = Convert.ToDouble(expression.Evaluate());
            Display = result.ToString();
        }
        catch
        {
            Display = "Error";
        }
    }

    public void AddDigit(string digit)
    {
        RemoveZeroFromStart();

        Display = Display + digit;
    }

    public void AddOperator(string operationSign)
    {
        // Implementation for setting the operation (e.g., +, -, ×, ÷)
        Display = Display + " " + operationSign + " ";
    }

    public void BackSpace()
    {
        if (Display.Length > 1)
        {
            Display = Display[..^1];
        }
        else
        {
            Display = "0";
        }
    }

    public void Clear()
    {
        Display = "0";
    }
}